# MAVSDK is one release contract: the server asset and generated gRPC client
# must come from the same upstream tag and protobuf submodule commit.
#
# To upgrade, update all three values, move third_party/mavsdk-proto to the
# commit referenced by the MAVSDK release tag, and run scripts/generate-mavsdk-go.sh.
ATLAS_MAVSDK_VERSION="v3.17.1"
ATLAS_MAVSDK_SHA256="dea8b9b30cbc2bbe35550b46244625c42c380ddfce9cbd47cd19d4cae66e2f2b"
ATLAS_MAVSDK_PROTO_COMMIT="d3cb35f49d1379d2d95a6d22cdbe40ff4074e9bf"
