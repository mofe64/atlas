#!/bin/sh
set -eu

: "${ATLAS_SPATIAL_CONTAINER_IMAGE:?ATLAS_SPATIAL_CONTAINER_IMAGE is required}"
: "${ATLAS_SPATIAL_CONTAINER_NAME:?ATLAS_SPATIAL_CONTAINER_NAME is required}"
: "${ATLAS_SPATIAL_PROVIDER:?ATLAS_SPATIAL_PROVIDER is required}"

if [ "${ATLAS_SPATIAL_ENABLED:-false}" != true ]; then
    printf '%s\n' 'spatial runtime is disabled in /etc/atlas-agent/spatial.env' >&2
    exit 1
fi

case "${ATLAS_SPATIAL_PROVIDER}" in
    synthetic)
        network_mode=none
        ;;
    depthai)
        # Standard libusb receives OAK firmware re-enumeration through a udev
        # monitor backed by the host netlink namespace. ROS remains host-local
        # through ROS_LOCALHOST_ONLY in the runtime image.
        network_mode=host
        ;;
    *)
        printf 'unsupported spatial provider: %s\n' "${ATLAS_SPATIAL_PROVIDER}" >&2
        exit 1
        ;;
esac

if [ "${ATLAS_SPATIAL_PROVIDER}" = depthai ] && [ ! -d /dev/bus/usb ]; then
    printf '%s\n' 'USB device bus is unavailable; retrying through systemd' >&2
    exit 1
fi
if [ "${ATLAS_SPATIAL_PROVIDER}" = depthai ] && [ ! -d /run/udev ]; then
    printf '%s\n' 'host udev database is unavailable; retrying through systemd' >&2
    exit 1
fi

agent_uid="$(id -u atlas-agent)"
agent_gid="$(id -g atlas-agent)"

# /run is cleared on reboot. The spatial service owns recreating its side of
# the shared Atlas runtime path so it does not depend on atlas-agent.service
# having started first.
/usr/bin/install -d -m 0750 -o atlas-agent -g atlas-agent \
    /run/atlas-agent \
    /var/lib/atlas-agent/spatial \
    /var/lib/atlas-agent/spatial/log

set -- \
    run --rm \
    --name "${ATLAS_SPATIAL_CONTAINER_NAME}" \
    --network "${network_mode}" \
    --user "${agent_uid}:${agent_gid}" \
    --env "ATLAS_SPATIAL_CONTRACT_VERSION=${ATLAS_SPATIAL_CONTRACT_VERSION:-1}" \
    --env "ATLAS_SPATIAL_PROVIDER=${ATLAS_SPATIAL_PROVIDER}" \
    --env "ATLAS_SPATIAL_SOURCE_ID=${ATLAS_SPATIAL_SOURCE_ID:-front-depth}" \
    --env "ATLAS_SPATIAL_DEVICE_ID=${ATLAS_SPATIAL_DEVICE_ID:-}" \
    --env "ATLAS_SPATIAL_MODEL=${ATLAS_SPATIAL_MODEL:-}" \
    --env "ATLAS_SPATIAL_USB_TRANSPORT=${ATLAS_SPATIAL_USB_TRANSPORT:-unknown}" \
    --env "ATLAS_SPATIAL_SOCKET_PATH=${ATLAS_SPATIAL_SOCKET_PATH:-/run/atlas-agent/spatial.sock}" \
    --env "ATLAS_SPATIAL_CLOUD_SOCKET_PATH=${ATLAS_SPATIAL_CLOUD_SOCKET_PATH:-/run/atlas-agent/spatial-cloud.sock}" \
    --env "ATLAS_SPATIAL_TRANSFORM_BUNDLE_PATH=${ATLAS_SPATIAL_TRANSFORM_BUNDLE_PATH:-/var/lib/atlas-agent/spatial/transforms.v1.json}" \
    --env "ATLAS_SPATIAL_VIO_ENABLED=${ATLAS_SPATIAL_VIO_ENABLED:-true}" \
    --env "ATLAS_SPATIAL_LIVE_CLOUD_ENABLED=${ATLAS_SPATIAL_LIVE_CLOUD_ENABLED:-true}" \
    --env "ATLAS_SPATIAL_PX4_VIO_FUSION_ENABLED=false" \
    --env "ATLAS_SPATIAL_MOVEMENT_ENABLED=false" \
    --env HOME=/var/lib/atlas-agent/spatial \
    --env ROS_LOG_DIR=/var/lib/atlas-agent/spatial/log \
    --read-only \
    --cap-drop ALL \
    --security-opt no-new-privileges \
    --tmpfs /tmp:rw,noexec,nosuid,size=128m \
    --volume /run/atlas-agent:/run/atlas-agent:rw \
    --volume /var/lib/atlas-agent/spatial:/var/lib/atlas-agent/spatial:rw

if [ "${ATLAS_SPATIAL_PROVIDER}" = depthai ]; then
    set -- "$@" \
        --device-cgroup-rule 'c 189:* rmw' \
        --volume /dev/bus/usb:/dev/bus/usb:rw \
        --volume /run/udev:/run/udev:ro
fi

exec /usr/bin/docker "$@" "${ATLAS_SPATIAL_CONTAINER_IMAGE}"
