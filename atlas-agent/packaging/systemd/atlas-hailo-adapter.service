[Unit]
Description=Atlas Hailo Perception Container
After=network-online.target docker.service atlas-agent.service dev-hailo0.device
Wants=network-online.target
Requires=docker.service atlas-agent.service dev-hailo0.device
PartOf=atlas-agent.service
ConditionPathExists=/etc/atlas-agent/atlas-agent.env
ConditionPathExists=/etc/atlas-agent/hailo-container.env
ConditionPathExists=/dev/hailo0

[Service]
Type=simple
EnvironmentFile=/etc/atlas-agent/hailo-container.env
ExecStartPre=/usr/bin/docker image inspect ${ATLAS_HAILO_CONTAINER_IMAGE}
ExecStartPre=-/usr/bin/docker rm -f ${ATLAS_HAILO_CONTAINER_NAME}
ExecStart=/usr/libexec/atlas-agent/atlas-hailo-container-run
ExecStop=/usr/bin/docker stop --time 10 ${ATLAS_HAILO_CONTAINER_NAME}
Restart=always
RestartSec=3
TimeoutStartSec=0
TimeoutStopSec=20
KillMode=process

[Install]
WantedBy=multi-user.target
