# These credentials are for local Docker development only. Production should
# inject secrets from its deployment platform rather than copying this file.
ATLAS_DB_NAME=atlas
ATLAS_DB_USER=atlas
ATLAS_DB_PASSWORD=atlas
ATLAS_DB_PORT=5432
ATLAS_HTTP_PORT=8080
ATLAS_SESSION_IDLE_TIMEOUT=12h
ATLAS_SESSION_ABSOLUTE_TIMEOUT=168h
ATLAS_SESSION_RETENTION=720h
