# Raster tile template used by the operational mission map. Keep {z}/{x}/{y}
# placeholders. The default is OpenStreetMap's public development tile service.
VITE_ATLAS_MAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png

# Raster DEM used for hillshade, geographic gimbal ROI altitude, and
# precomputed terrain-aware mission profiles. Atlas supports Terrarium and
# Mapbox Terrain-RGB encodings. The public default is the Mapzen dataset in
# the AWS Open Data Registry.
VITE_ATLAS_TERRAIN_TILE_URL=https://s3.amazonaws.com/elevation-tiles-prod/terrarium/{z}/{x}/{y}.png
VITE_ATLAS_TERRAIN_ENCODING=terrarium
VITE_ATLAS_TERRAIN_ZOOM=12
VITE_ATLAS_TERRAIN_DATASET_ID=mapzen-aws-terrain-tiles
VITE_ATLAS_TERRAIN_NAME=Mapzen Terrain Tiles on AWS
